# ============================================================
# Anime World API — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
APP_NAME="Anime World API"
APP_VERSION="1.0.0"
# development | staging | production
ENVIRONMENT=development
DEBUG=false
PORT=8001

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=anime_world

# Connection pool
DB_MIN_POOL_SIZE=5
DB_MAX_POOL_SIZE=20
DB_CONNECT_TIMEOUT_MS=5000
DB_SERVER_SELECTION_TIMEOUT_MS=5000

# ------------------------------------------------------------------
# JWT / Authentication
# ------------------------------------------------------------------
# IMPORTANT: Change this to a long random string in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-to-a-long-random-secret-in-production

JWT_EXPIRATION_HOURS=72
JWT_REFRESH_EXPIRATION_DAYS=30

# ------------------------------------------------------------------
# Security
# ------------------------------------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
PASSWORD_RESET_EXPIRY_HOURS=24
PASSWORD_MIN_LENGTH=8

# ------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------
# Comma-separated list of allowed origins.
# Use "*" for development only — never in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# ------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------
RATE_LIMIT_ENABLED=false
RATE_LIMIT_AUTH_RPM=10
RATE_LIMIT_API_RPM=120

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Set to true in production for structured JSON logs
LOG_JSON=false

# ------------------------------------------------------------------
# Error Tracking (Sentry)
# ------------------------------------------------------------------
# Leave empty to disable Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ------------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------------
FEATURE_EMAIL_VERIFICATION=false
FEATURE_PREMIUM_CONTENT=false
FEATURE_OAUTH2=false
FEATURE_WEBHOOKS=false

# ------------------------------------------------------------------
# File Uploads
# ------------------------------------------------------------------
# Directory for uploaded files (relative to backend/)
UPLOAD_DIR=uploads
MAX_AVATAR_SIZE_MB=20
